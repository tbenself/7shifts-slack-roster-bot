# Slack app credentials.
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Optional but recommended: comma-separated Slack workspace IDs allowed to use this bot.
# The value will look like T012ABCDEF and can be found in Slack app event payloads/logs.
SLACK_ALLOWED_TEAM_IDS=

# 7shifts credentials.
SEVENSHIFTS_ACCESS_TOKEN=
# Also supported if this is how the key is already named:
# SEVENSHIFTS_API_KEY=
SEVENSHIFTS_COMPANY_ID=

# Some 7shifts bearer tokens still require the company grant GUID header.
# Leave blank first if you only have a token; add it if 7shifts returns a GUID/header error.
SEVENSHIFTS_COMPANY_GUID=
SEVENSHIFTS_API_VERSION=2025-03-01

# Optional OAuth fallback if 7shifts later gives you an OAuth app instead of a static token.
SEVENSHIFTS_CLIENT_ID=
SEVENSHIFTS_CLIENT_SECRET=
SEVENSHIFTS_SCOPES=shifts:read users:read locations:read roles:read

# App behavior.
PORT=3000
TIME_ZONE=America/New_York
NAME_FORMAT=first_last_initial

# Optional, but useful before the first live 7shifts location sync succeeds.
# Values can be numeric 7shifts location IDs or exact 7shifts location names.
LOCATION_ALIASES_JSON={"downtown":"Downtown Taproom","dt":"Downtown Taproom","riverside":"Riverside Bar","events":"Events Team"}

# Optional: comma-separated Slack channel IDs if you later want to allow channels.
# DMs are always allowed.
ALLOWED_CHANNEL_IDS=

# Optional: comma-separated Slack user IDs allowed to request aggregate usage stats.
# If blank, any allowed Slack user can DM "usage" or "stats".
USAGE_ALLOWED_USER_IDS=
